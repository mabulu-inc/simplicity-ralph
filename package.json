{
  "name": "@smplcty/ralph",
  "version": "0.8.4",
  "description": "Stateless, PRD-driven AI development loop — automated TDD with Claude Code, Gemini CLI, Codex, Continue, and Cursor",
  "repository": {
    "type": "git",
    "url": "https://github.com/mabulu-inc/simplicity-ralph.git"
  },
  "type": "module",
  "main": "./dist/ralph/cli.js",
  "bin": {
    "ralph": "./dist/ralph/bin.js"
  },
  "scripts": {
    "lint": "eslint src/",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm format && pnpm typecheck && pnpm build && pnpm test:coverage",
    "milestones": "node dist/ralph/bin.js milestones",
    "ralph": "node dist/ralph/bin.js loop",
    "ralph:kill": "node dist/ralph/bin.js kill",
    "shas": "node dist/ralph/bin.js shas",
    "cost": "node dist/ralph/bin.js cost",
    "monitor": "node dist/ralph/bin.js monitor -w",
    "monitor:once": "node dist/ralph/bin.js monitor",
    "prepare": "husky",
    "release:patch": "pnpm version patch && git push && git push --tags && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "release:minor": "pnpm version minor && git push && git push --tags && gh release create v$(node -p \"require('./package.json').version\") --generate-notes",
    "release:major": "pnpm version major && git push && git push --tags && gh release create v$(node -p \"require('./package.json').version\") --generate-notes"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/mdast": "^4.0.4",
    "chalk": "^5.3.0",
    "mdast-util-to-string": "^4.0.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.0.18"
  }
}
